# Provider mode: mock | agent_framework
ROMA_PROVIDER=mock
ROMA_AGENT_RUNTIME=auto

# Model/provider settings
ROMA_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BACKOFF_SECONDS=1.5
OPENAI_MAX_TOKENS=4096
OPENAI_THINKING_TYPE=disabled
# Optional Azure Foundry settings
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT_NAME=
# Optional for Azure auth (recommended: run `az login` locally)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Search settings
ROMA_SEARCH_PROVIDER=tavily
ROMA_MAX_SOURCES=8
TAVILY_API_KEY=
BING_SEARCH_V7_ENDPOINT=
BING_SEARCH_V7_KEY=

# Output settings
ROMA_OUTPUT_DIR=output

# Image consul settings
ROMA_ENABLE_IMAGE_CONSUL=false
ROMA_IMAGE_MODEL=gpt-image-1
ROMA_IMAGE_COUNT=2
ROMA_IMAGE_SIZE=512x512
ROMA_IMAGE_POLL_INTERVAL_SECONDS=3
ROMA_IMAGE_POLL_TIMEOUT_SECONDS=180

# Article length settings
ROMA_ARTICLE_MIN_WORDS=1200
ROMA_ARTICLE_MAX_WORDS=1800

# Senate quality rework thresholds
ROMA_SENATE_REJECT_SCORE_THRESHOLD=80
ROMA_SENATE_MAX_REWORK_ROUNDS=2

